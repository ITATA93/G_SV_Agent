# ============================
# Genesis OS - Environment
# G_SV_Agent Configuration
# ============================

# ---------------------------
# Postgres (local dev)
# ---------------------------
POSTGRES_DB=genesis
POSTGRES_USER=genesis
POSTGRES_PASSWORD=genesis_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------
# MCP/API server
# ---------------------------
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# ---------------------------
# Memory / Embeddings
# Options: dummy | openai | google
# ---------------------------
EMBEDDING_PROVIDER=dummy
EMBEDDING_DIM=1536

# ---------------------------
# App / Governance
# ---------------------------
DEFAULT_PROJECT_NAME=local-dev

# ---------------------------
# VM101 Infrastructure (SSH)
# ---------------------------
PROXMOX_IP=65.21.233.178
PROXMOX_SSH_USER=root
VM_SERVICES_IP=10.10.10.101
VM_SERVICES_USER=matias

# ---------------------------
# Langfuse (LLM Observability)
# Obtain from: https://app.langfuse.com or self-hosted instance
# See docs/CREDENTIAL_SETUP.md for instructions
# ---------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=sk-lf-CHANGEME
LANGFUSE_HOST=https://langfuse.imedicina.cl

# ---------------------------
# Notion Integration
# Obtain from: https://www.notion.so/my-integrations
# See docs/CREDENTIAL_SETUP.md for instructions
# ---------------------------
NOTION_TOKEN=ntn_CHANGEME
NOTION_DATABASE_ID=

# ---------------------------
# Azure AD (Microsoft Graph)
# Obtain from: https://portal.azure.com > App registrations
# See docs/CREDENTIAL_SETUP.md for instructions
# ---------------------------
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# ---------------------------
# Gmail OAuth (G_TaskCenter)
# Obtain from: https://console.cloud.google.com
# See docs/CREDENTIAL_SETUP.md for instructions
# ---------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# ---------------------------
# Tailscale VPN (optional)
# Obtain from: https://login.tailscale.com/admin/settings/keys
# See docs/CREDENTIAL_SETUP.md for instructions
# ---------------------------
TAILSCALE_AUTH_KEY=tskey-auth-CHANGEME

# ---------------------------
# Portainer (VM101 management)
# Set before running scripts/init_portainer.sh
# ---------------------------
PORTAINER_PORT=9443
PORTAINER_ADMIN_USER=admin
PORTAINER_ADMIN_PASSWORD=

# ---------------------------
# Prometheus (VM101 monitoring)
# ---------------------------
PROMETHEUS_HOST=https://prometheus.imedicina.cl
PROMETHEUS_PORT=9090

# ---------------------------
# PostgREST JWT
# ---------------------------
POSTGREST_JWT_SECRET=
