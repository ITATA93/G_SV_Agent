# ============================
# Genesis OS - Environment
# G_SV_Agent Configuration
# Last updated: 2026-03-02
# Service registry: configs/services.yml (24 services)
# ============================

# ==============================================================
# SECTION A: LOCAL DEVELOPMENT
# ==============================================================

# ---------------------------
# Postgres (local dev)
# ---------------------------
POSTGRES_DB=genesis
POSTGRES_USER=genesis
POSTGRES_PASSWORD=genesis_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------
# MCP/API server
# ---------------------------
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# ---------------------------
# Memory / Embeddings
# Options: dummy | openai | google
# ---------------------------
EMBEDDING_PROVIDER=dummy
EMBEDDING_DIM=1536

# ---------------------------
# App / Governance
# ---------------------------
DEFAULT_PROJECT_NAME=local-dev

# ==============================================================
# SECTION B: PRODUCTION INFRASTRUCTURE
# For full credentials, see .env (not committed to git)
# ==============================================================

# ---------------------------
# Physical Server (Proxmox Host)
# ---------------------------
PROXMOX_HOST=https://65.21.233.178:8006
PROXMOX_IP=65.21.233.178
PROXMOX_SSH_USER=root
PROXMOX_NODE=antigravity-core
# PROXMOX_TOKEN=root@pam!AG=CHANGEME

# ---------------------------
# Virtual Machines
# ---------------------------
VM_DEV_ID=100
VM_DEV_IP=10.10.10.100
VM_SERVICES_ID=101
VM_SERVICES_IP=10.10.10.101
VM_SERVICES_USER=matias

# ---------------------------
# Global Admin (n8n, NocoBase, Saltcorn, DHIS2, Node-RED)
# ---------------------------
GLOBAL_ADMIN_EMAIL=
GLOBAL_ADMIN_PASSWORD=

# ---------------------------
# Databases (PostgreSQL — VM101)
# ---------------------------
DB_HOST=10.10.10.101
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=
DB_NAMES=n8n,nocobase,saltcorn,services

# ---------------------------
# Cloudflare
# ---------------------------
CLOUDFLARE_DOMAIN=imedicina.cl
# CLOUDFLARE_API_TOKEN=CHANGEME
# CLOUDFLARE_TUNNEL_ID=CHANGEME

# ---------------------------
# NocoBase (dev) — Port 13000
# ---------------------------
NOCOBASE_BASE_URL=https://nocobase.imedicina.cl
NOCOBASE_PORT=13000
NOCOBASE_APP_KEY=
NOCOBASE_API_TOKEN=

# ---------------------------
# NocoBase MIRA (Hospital de Ovalle) — Port 13003
# ---------------------------
NOCOBASE_MIRA_URL=https://mira.hospitaldeovalle.cl
NOCOBASE_MIRA_PORT=13003
NOCOBASE_MIRA_VERSION=1.9.14
NOCOBASE_MIRA_DB_NAME=nocobase_mira

# ---------------------------
# NocoBase MIRA2 — Port 13002
